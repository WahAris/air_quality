# ─────────────────────────────────────────────────────────
# AirWatch Backend - Environment Variables Template
#
# CARA PENGGUNAAN:
#   1. Salin file ini: cp .env.example .env
#   2. Isi nilai yang sesuai di file .env
#   3. JANGAN PERNAH commit file .env ke Git!
# ─────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────
# Dapatkan dari: https://app.supabase.com -> Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Model Directory ───────────────────────────────────────
# Path ke direktori model ML (relatif dari folder backend)
MODEL_DIR=./models

# ── CORS (Cross-Origin Resource Sharing) ─────────────────
# URL frontend yang diizinkan mengakses backend
# Pisahkan dengan koma jika lebih dari satu
ALLOWED_ORIGINS=http://localhost:5173

# ── Server (Opsional) ─────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
# RELOAD=true
